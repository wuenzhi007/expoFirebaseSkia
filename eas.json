{
  "cli": {
    "version": ">= 3.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "ios": {
        "workflow": "managed"
      },
      "android": {
        "workflow": "managed"
      }
    },
    "production": {
      "ios": {
        "workflow": "managed",
        "buildType": "release"
      },
      "android": {
        "workflow": "managed",
        "buildType": "app-bundle"
      }
    }
  }
}
